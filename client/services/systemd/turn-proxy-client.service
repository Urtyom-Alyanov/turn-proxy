[Unit]
Description=DTLS TURN Proxy Server
After=network.target
Documentation=https://github.com/Urtyom-Alyanov/turn-proxy-proxy

[Service]
ExecStart=/usr/bin/turn-proxy-client --config /etc/turn-proxy/server/config.toml

Restart=always
RestartSec=5

LimitNOFILE=65535

Environment=RUST_LOG=info

StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target