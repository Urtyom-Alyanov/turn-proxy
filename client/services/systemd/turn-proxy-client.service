[Unit]
Description=DTLS TURN Proxy Client
After=network.target
Documentation=https://github.com/Urtyom-Alyanov/turn-proxy

[Service]
ExecStart=/usr/bin/turn-proxy-client --config /etc/turn-proxy/client/config.toml from-config-file

Restart=always
RestartSec=5

LimitNOFILE=65535

Environment=RUST_LOG=info

StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
